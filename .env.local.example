# ─── Supabase ────────────────────────────────────────────────────────────────
# From: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # Never expose publicly

# ─── Anthropic (Claude API) ───────────────────────────────────────────────────
# From: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (email notifications) ────────────────────────────────────────────
# From: https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=GiftRadar <reminders@yourdomain.com>

# ─── Twilio (SMS notifications) ───────────────────────────────────────────────
# From: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890   # Your Twilio number in E.164 format

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com   # Used in notification links

# ─── Cron security ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-string
